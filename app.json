{
  "expo": {
    "name": "Scratch Card Dialer",
    "slug": "scanio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0E1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.scanio.scratchcarddialer",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan your scratch card barcode or number.",
        "NSPhotoLibraryUsageDescription": "Access photos to scan scratch card images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E1A"
      },
      "package": "com.scanio.scratchcarddialer",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.CALL_PHONE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Scratch Card Dialer to access your camera to scan Shit"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "188191eb-5ef2-4b34-afa5-be1c5ea38d11"
      }
    }
  }
}

